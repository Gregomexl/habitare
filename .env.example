# Database Configuration
HABITARE_DATABASE_URL=postgresql+asyncpg://habitare_user:habitare_dev_password@localhost:5432/habitare
HABITARE_REDIS_URL=redis://localhost:6379/0

# Security & JWT
HABITARE_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
HABITARE_ALGORITHM=HS256
HABITARE_ACCESS_TOKEN_EXPIRE_MINUTES=30
HABITARE_REFRESH_TOKEN_EXPIRE_DAYS=14

# Fernet Encryption (for TOTP secrets)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
HABITARE_FERNET_KEY=change-me-generate-with-fernet

# CORS Configuration
HABITARE_FRONTEND_URL=http://localhost:3000
HABITARE_CORS_ORIGINS=["http://localhost:3000"]

# Environment
HABITARE_ENVIRONMENT=development
HABITARE_DEBUG=true

# Database Password (for docker-compose)
DB_PASSWORD=habitare_dev_password

# OAuth Providers (to be configured later)
# HABITARE_GOOGLE_CLIENT_ID=
# HABITARE_GOOGLE_CLIENT_SECRET=
# HABITARE_APPLE_CLIENT_ID=
# HABITARE_APPLE_CLIENT_SECRET=

# Email delivery (Resend — https://resend.com)
HABITARE_RESEND_API_KEY=re_your_key_here
HABITARE_FROM_EMAIL=noreply@yourdomain.com
HABITARE_EMAIL_ENABLED=true
# CORS allowed origins (JSON array string)
HABITARE_CORS_ORIGINS=["http://localhost:3000"]
